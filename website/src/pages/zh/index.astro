---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/sections/Hero.astro';
import Deaths from '../../components/sections/Deaths.astro';
import Philosophy from '../../components/sections/Philosophy.astro';
import Attention from '../../components/sections/Attention.astro';
import Watch from '../../components/sections/Watch.astro';
import Story from '../../components/sections/Story.astro';
import Evolution from '../../components/sections/Evolution.astro';
import Architecture from '../../components/sections/Architecture.astro';
import Quickstart from '../../components/sections/Quickstart.astro';
import { zh as ui } from '../../i18n/ui.zh';

const description =
  'cc-master 把任意受支持的 coding-agent 会话初始化成 master orchestrator——拆目标成 DAG、并行推进、按配额配速、只在该问你时问你。';
---

<Base title="cc-master —— 长程 agent 的指挥台" description={description} lang="zh">
  <Header lang="zh" ui={ui} />
  <main>
    <Hero ui={ui} />
    <Deaths ui={ui} />
    <Philosophy ui={ui} />
    <Attention ui={ui} />
    <Watch ui={ui} />
    <Story ui={ui} />
    <Evolution ui={ui} />
    <Architecture ui={ui} />
    <Quickstart ui={ui} lang="zh" />
  </main>
  <Footer lang="zh" ui={ui} />
  <script>
    import '../../islands/reveal.ts';
    import '../../islands/dag-canvas.ts';
    import '../../islands/typing.ts';
    import '../../islands/theme-toggle.ts';
  </script>
</Base>

---
import { getCollection, render } from 'astro:content';
import Docs from '../../../layouts/Docs.astro';

export async function getStaticPaths() {
  const entries = await getCollection('docs');
  return entries
    .filter((e) => e.id.startsWith('zh/'))
    .map((e) => ({
      params: { slug: e.id.slice(3) },
      props: { entry: e },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const currentId = entry.id.slice(3);
---

<Docs lang="zh" title={entry.data.title} description={entry.data.description} section={entry.data.section} currentId={currentId}>
  <Content />
  {entry.data.deeper.length > 0 && (
    <div class="deeper">
      <p class="eyebrow" style="margin-top:0">深入阅读 — 仓库里的真相源</p>
      <ul style="margin-top:10px">
        {entry.data.deeper.map((l) => (
          <li><a href={l.url} target="_blank" rel="noopener">{l.label}</a></li>
        ))}
      </ul>
    </div>
  )}
</Docs>

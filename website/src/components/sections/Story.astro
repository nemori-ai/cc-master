---
import SectionHead from '../SectionHead.astro';
import ShotFrame from '../ShotFrame.astro';
import type { Ui } from '../../i18n/ui';

interface Props { ui: Ui }
const { ui } = Astro.props;
---

<section id="story" class="border-t border-hair-soft py-20 md:py-24">
  <div class="mx-auto max-w-6xl px-6">
    <SectionHead eyebrow={ui.story.eyebrow} title={ui.story.title} />

    <div class="mt-14 space-y-16">
      {ui.story.steps.map((s, i) => (
        <div class={`grid items-center gap-8 lg:grid-cols-2 ${i % 2 === 1 ? 'lg:[&>*:first-child]:order-2' : ''}`}>
          <div class="reveal">
            <span class="tele text-[11px] font-semibold tracking-[0.2em] text-spine uppercase">{s.k}</span>
            <h3 class="mt-3 text-2xl font-extrabold tracking-tight">{s.title}</h3>
            <p class="mt-3 max-w-lg text-[14.5px] leading-relaxed text-ink-dim text-pretty">{s.body}</p>
          </div>
          <div class="reveal" style="--reveal-delay:120ms">
            {s.shot ? (
              <ShotFrame name={s.shot} caption="" alt={s.title} />
            ) : (
              <div class="overflow-hidden rounded-[11px] border border-hair bg-[oklch(0.145_0.012_255)] shadow-[var(--elev-shot)]">
                <div class="flex items-center gap-1.5 border-b border-white/10 px-3 py-2">
                  <span class="inline-block h-[9px] w-[9px] rounded-full bg-white/15"></span>
                  <span class="inline-block h-[9px] w-[9px] rounded-full bg-white/15"></span>
                  <span class="inline-block h-[9px] w-[9px] rounded-full bg-white/15"></span>
                  <span class="tele ml-2 text-[10px] tracking-[0.14em] text-white/40 uppercase">your harness</span>
                </div>
                <div class="px-5 py-8 md:px-8 md:py-10">
                  <code class="tele block text-[13px] leading-relaxed text-[oklch(0.93_0.008_255)] md:text-[14.5px]">
                    <span class="text-[oklch(0.66_0.13_244)]">❯</span> /cc-master:as-master-orchestrator <span class="text-[oklch(0.8_0.16_70)]">Internationalize the app to 6 locales</span>
                  </code>
                  <p class="tele mt-3 text-[11px] text-white/35">i18n framework + per-locale translation + locale routing</p>
                </div>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>

    <p class="reveal mt-16 text-center">
      <span class="inline-block rounded-full border border-spine/40 bg-spine/10 px-5 py-2 text-[14px] font-semibold text-spine">{ui.story.kicker}</span>
    </p>
  </div>
</section>

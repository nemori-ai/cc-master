---
import SectionHead from '../SectionHead.astro';
import ShotFrame from '../ShotFrame.astro';
import type { Ui } from '../../i18n/ui';

interface Props { ui: Ui }
const { ui } = Astro.props;

const tone = ['--ready', '--inflight', '--spine'] as const;
---

<section class="border-t border-hair-soft py-20 md:py-24">
  <div class="mx-auto max-w-6xl px-6">
    <SectionHead eyebrow={ui.attention.eyebrow} title={ui.attention.title} lead={ui.attention.lead} />

    <div class="mt-12 grid gap-4 lg:grid-cols-3">
      {ui.attention.tags.map((t, i) => (
        <div class="reveal panel flex flex-col p-6" style={`--reveal-delay:${i * 90}ms`}>
          <div class="flex items-center justify-between gap-2">
            <code class="tele text-[14px] font-semibold" style={`color: var(${tone[i]})`}>{t.tag}</code>
            <span class="tele rounded border border-hair px-1.5 py-0.5 text-[10px] tracking-[0.12em] text-ink-faint uppercase">{t.strength}</span>
          </div>
          <p class="mt-3 flex-1 text-[13.5px] leading-relaxed text-ink-dim">{t.body}</p>
          <pre class="tele mt-4 overflow-x-auto rounded-[7px] bg-[oklch(0.145_0.012_255)] p-3 text-[11px] leading-relaxed break-words whitespace-pre-wrap text-[oklch(0.75_0.02_255)]"><code>{t.example}</code></pre>
        </div>
      ))}
    </div>

    <div class="mt-16 grid items-center gap-8 lg:grid-cols-2">
      <div class="reveal">
        <h3 class="text-2xl font-extrabold tracking-tight text-balance">{ui.attention.decisionTitle}</h3>
        <p class="mt-4 text-[15px] leading-relaxed text-ink-dim text-pretty">{ui.attention.decisionBody}</p>
        <a href="#watch" class="tele mt-5 inline-flex items-center gap-2 text-[12px] font-semibold tracking-wide text-spine uppercase">
          {ui.attention.decisionCta} <span aria-hidden="true">↓</span>
        </a>
      </div>
      <div class="reveal" style="--reveal-delay:120ms">
        <ShotFrame name="viewer-decision-dark" caption="D1 — “Split the PR into two?” · context · options · tradeoffs" alt="a decision card in the ccm web-viewer: question, context, options and tradeoffs" />
      </div>
    </div>

    <div class="reveal mt-16">
      <h3 class="text-lg font-bold">{ui.attention.explainTitle}</h3>
      <div class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {ui.attention.explain.map(([name, desc]) => (
          <div class="panel-hi p-4">
            <p class="text-[13.5px] font-bold"><span class="lamp mr-1.5 text-done" style="width:6px;height:6px"></span>{name}</p>
            <p class="mt-2 text-[12.5px] leading-relaxed text-ink-dim">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

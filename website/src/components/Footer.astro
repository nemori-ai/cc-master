---
interface Props {
  lang: 'en' | 'zh';
  ui: {
    footer: {
      honesty: string;
      built: string;
      links: Record<string, string>;
    };
  };
}
const { lang, ui } = Astro.props;
const home = lang === 'zh' ? '/zh/' : '/';
const GH = 'https://github.com/nemori-ai/cc-master';
---

<footer class="border-t border-hair-soft">
  <div class="mx-auto max-w-6xl px-6 py-12">
    <div class="flex flex-col gap-8 md:flex-row md:items-start md:justify-between">
      <div class="max-w-md">
        <div class="flex items-center gap-2.5">
          <span class="inline-block h-2 w-2 rounded-full bg-done shadow-[0_0_6px_var(--done)]"></span>
          <span class="text-[14px] font-bold">{ui.footer.built}</span>
        </div>
        <p class="mt-3 text-[12.5px] leading-relaxed text-ink-faint">{ui.footer.honesty}</p>
      </div>
      <nav class="grid grid-cols-2 gap-x-12 gap-y-2 text-[13px] text-ink-dim sm:grid-cols-3">
        <a class="hover:text-ink" href={`${home}docs/getting-started`}>{ui.footer.links.docs}</a>
        <a class="hover:text-ink" href={`${GH}/blob/main/design_docs/feature-manual.md`} target="_blank" rel="noopener">{ui.footer.links.featureManual}</a>
        <a class="hover:text-ink" href={`${GH}/releases`} target="_blank" rel="noopener">{ui.footer.links.releases}</a>
        <a class="hover:text-ink" href={GH} target="_blank" rel="noopener">{ui.footer.links.github}</a>
        <a class="hover:text-ink" href={`${GH}/blob/main/LICENSE`} target="_blank" rel="noopener">{ui.footer.links.license}</a>
      </nav>
    </div>
    <div class="tele mt-10 flex items-center justify-between border-t border-hair-soft pt-5 text-[10.5px] tracking-[0.14em] text-ink-faint uppercase">
      <span>© 2026 cc-master contributors</span>
      <span class="hidden sm:inline">conduct · don't play</span>
    </div>
  </div>
</footer>

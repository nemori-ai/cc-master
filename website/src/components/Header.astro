---
interface Props {
  lang: 'en' | 'zh';
  ui: {
    nav: Record<string, string>;
  };
}
const { lang, ui } = Astro.props;
const home = lang === 'zh' ? '/zh/' : '/';
const alt = lang === 'zh' ? '/' : '/zh/';
const altLabel = lang === 'zh' ? 'EN' : '中文';
const a = (id: string) => `${home}#${id}`;
---

<header class="sticky top-0 z-40 border-b border-hair-soft bg-ground/80 backdrop-blur-md">
  <div class="mx-auto flex h-14 max-w-6xl items-center gap-5 px-6">
    <a href={home} class="flex items-center gap-2.5">
      <span class="inline-block h-2 w-2 rounded-full bg-done shadow-[0_0_6px_var(--done)]"></span>
      <span class="text-[15px] font-bold tracking-tight">cc-master</span>
      <span class="tele mt-px hidden text-[10px] tracking-[0.18em] text-ink-faint uppercase sm:inline">mission control</span>
    </a>

    <nav class="ml-auto hidden items-center gap-5 text-[13px] text-ink-dim md:flex">
      <a class="hover:text-ink" href={a('philosophy')}>{ui.nav.philosophy}</a>
      <a class="hover:text-ink" href={a('watch')}>{ui.nav.watch}</a>
      <a class="hover:text-ink" href={a('story')}>{ui.nav.story}</a>
      <a class="hover:text-ink" href={a('evolution')}>{ui.nav.evolution}</a>
      <a class="hover:text-ink" href={a('architecture')}>{ui.nav.architecture}</a>
      <a class="hover:text-ink" href={`${home}docs/getting-started`}>{ui.nav.docs}</a>
    </nav>

    <div class="ml-auto flex items-center gap-2 md:ml-4">
      <a
        href="https://github.com/nemori-ai/cc-master"
        class="rounded-md p-2 text-ink-dim hover:text-ink"
        aria-label="GitHub"
        target="_blank"
        rel="noopener"
      >
        <svg width="17" height="17" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/></svg>
      </a>
      <a href={alt} class="tele rounded-md border border-hair px-2 py-1 text-[11px] text-ink-dim hover:text-ink">{altLabel}</a>
      <button
        data-theme-toggle
        class="rounded-md border border-hair p-1.5 text-ink-dim hover:text-ink"
        aria-label="toggle day / night theme"
        title="toggle day / night theme"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4.2" fill="currentColor" stroke="none" opacity="0.9"/>
          <path d="M12 2.5v2.4M12 19.1v2.4M2.5 12h2.4M19.1 12h2.4M4.9 4.9l1.7 1.7M17.4 17.4l1.7 1.7M19.1 4.9l-1.7 1.7M6.6 17.4l-1.7 1.7"/>
        </svg>
      </button>
    </div>
  </div>
</header>

  "title": "容量与截止期决策",
  "intent": "在 effect floor、selected-target 事实、容量走廊与交付 DDL 之间做守边界的资源决策。",
  "recognition_cues": ["容量收紧", "需要分配模型档", "board 背着交付 DDL"],
  "boundary": {"includes": ["模型分配", "容量收缩顺序", "DDL 编排纪律"], "excludes": ["动态 provider catalog", "account 换号授权与命令"]},

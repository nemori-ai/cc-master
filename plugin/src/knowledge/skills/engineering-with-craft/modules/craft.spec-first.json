  "schema_version": "cc-master/skill-knowledge-source/v1alpha1",
  "kind": "module",
  "id": "module:craft.spec-first",
  "owner_skill": "skill:engineering-with-craft",
  "title": "SDD Spec-first",
  "intent": "判断何时需要 spec-first，并让 spec 成为实现、测试和变更的唯一契约裁判。",
  "recognition_cues": [
    "跨边界接口需要先定契约",
    "实现与 spec 可能漂移"
  ],
  "boundary": {
    "includes": [
      "spec 边界与准入",
      "spec/impl/test 对齐",
      "实现前硬闸",
      "漂移红线"
    ],
    "excludes": [
      "对象内部实现品味",
      "测试红绿步骤"
    ]
  },
  "access": {
    "class": "primary",
    "relevant_entries": [
      "entry:engineering-craft"
    ],
    "primary_points": [
      "point:sdd.core-belief"
    ],
    "rationale": "SDD Spec-first是该认知职责的主干入口。"
  },
  "lifecycle": {
    "state": "accepted",
    "since": "2026-07-24"
  },

      "title": "SDD 适用性判断",
      "point_kind": "decision_rule",
      "summary": "按跨边界、多消费者、稳定性、并行与不变式密度决定是否值得 spec-first。",
      "recognition_cues": [
        "需要SDD 适用性判断"
      ],

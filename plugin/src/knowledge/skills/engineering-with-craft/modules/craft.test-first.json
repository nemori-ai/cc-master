  "kind": "module",
  "id": "module:craft.test-first",
  "owner_skill": "skill:engineering-with-craft",
  "title": "TDD Test-first",
  "intent": "执行可验证的 RED→GREEN→REFACTOR，并用真实约束和末端证据守住完成声明。",
  "recognition_cues": [
    "准备写产品代码却没有失败测试",
    "测试全绿但真实约束未验证"
  ],
  "boundary": {
    "includes": [
      "TDD 铁律",
      "红绿重构",
      "constraint parity",
      "completion gate"
    ],
    "excludes": [
      "执行任务的优化循环形状",
      "spec 的准入判断"
    ]
  },

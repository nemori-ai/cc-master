  "id": "module:craft.object-design",
  "owner_skill": "skill:engineering-with-craft",
  "title": "OOP 对象设计",
  "intent": "用四柱、SOLID 判断、封装和组合设计有清晰边界且能在生产存活的对象。",
  "recognition_cues": [
    "判断一个类的责任或抽象是否合理",
    "纠结继承还是组合"
  ],

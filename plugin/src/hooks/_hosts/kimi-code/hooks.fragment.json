[
  {
    "event": "UserPromptSubmit",
    "command": "node \"$KIMI_PLUGIN_ROOT/hooks/_hosts/kimi-code/launcher.js\" --event UserPromptSubmit --core \"$KIMI_PLUGIN_ROOT/hooks/bootstrap-board/implementations/kimi-code/bootstrap-board-core.js\"",
    "timeout": 45
  },
  {
    "event": "PreToolUse",
    "matcher": "Bash|Write|Edit|MultiEdit",
    "command": "node \"$KIMI_PLUGIN_ROOT/hooks/_hosts/kimi-code/launcher.js\" --event PreToolUse --core \"$KIMI_PLUGIN_ROOT/hooks/board-guard/implementations/kimi-code/board-guard-core.js\"",
    "timeout": 15
  },
  {
    "event": "PostToolUse",
    "matcher": "Write|Edit|MultiEdit",
    "command": "node \"$KIMI_PLUGIN_ROOT/hooks/_hosts/kimi-code/launcher.js\" --event PostToolUse --core \"$KIMI_PLUGIN_ROOT/hooks/board-lint/implementations/kimi-code/board-lint-core.js\"",
    "timeout": 20
  },
  {
    "event": "Stop",
    "command": "node \"$KIMI_PLUGIN_ROOT/hooks/_hosts/kimi-code/launcher.js\" --event Stop --core \"$KIMI_PLUGIN_ROOT/hooks/verify-board/implementations/kimi-code/verify-board-core.js\"",
    "timeout": 30
  },
  {
    "event": "PostCompact",
    "command": "node \"$KIMI_PLUGIN_ROOT/hooks/_hosts/kimi-code/launcher.js\" --event PostCompact --core \"$KIMI_PLUGIN_ROOT/hooks/reinject/implementations/kimi-code/reinject-core.js\"",
    "timeout": 10
  }
]

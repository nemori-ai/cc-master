{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "CC_MASTER_CURSOR_HOOK_PROBE_EVENT=sessionStart CC_MASTER_CURSOR_HOOK_PROBE_MODE=context CC_MASTER_CURSOR_HOOK_PROBE_DIR=\"{{PROBE_DIR}}\" node \"{{PLUGIN_ROOT}}/hooks/probe-hook.js\""
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "CC_MASTER_CURSOR_HOOK_PROBE_EVENT=beforeSubmitPrompt CC_MASTER_CURSOR_HOOK_PROBE_MODE=silent CC_MASTER_CURSOR_HOOK_PROBE_DIR=\"{{PROBE_DIR}}\" node \"{{PLUGIN_ROOT}}/hooks/probe-hook.js\""
      }
    ],
    "preToolUse": [
      {
        "command": "CC_MASTER_CURSOR_HOOK_PROBE_EVENT=preToolUse CC_MASTER_CURSOR_HOOK_PROBE_MODE=silent CC_MASTER_CURSOR_HOOK_PROBE_DIR=\"{{PROBE_DIR}}\" node \"{{PLUGIN_ROOT}}/hooks/probe-hook.js\"",
        "matcher": "Shell|Write|Read"
      }
    ],
    "postToolUse": [
      {
        "command": "CC_MASTER_CURSOR_HOOK_PROBE_EVENT=postToolUse CC_MASTER_CURSOR_HOOK_PROBE_MODE=context CC_MASTER_CURSOR_HOOK_PROBE_DIR=\"{{PROBE_DIR}}\" node \"{{PLUGIN_ROOT}}/hooks/probe-hook.js\"",
        "matcher": "Shell|Write|Read"
      }
    ],
    "stop": [
      {
        "command": "CC_MASTER_CURSOR_HOOK_PROBE_EVENT=stop CC_MASTER_CURSOR_HOOK_PROBE_MODE=silent CC_MASTER_CURSOR_HOOK_PROBE_DIR=\"{{PROBE_DIR}}\" node \"{{PLUGIN_ROOT}}/hooks/probe-hook.js\"",
        "loop_limit": 3
      }
    ]
  }
}

{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "command": "node \"./hooks/_hosts/cursor/launcher.js\" --event beforeSubmitPrompt --core \"./hooks/bootstrap-board/implementations/cursor/bootstrap-board-core.js\""
      }
    ],
    "preToolUse": [
      {
        "command": "node \"./hooks/_hosts/cursor/launcher.js\" --event preToolUse --core \"./hooks/board-guard/implementations/cursor/board-guard-core.js\"",
        "matcher": "Shell|Write"
      }
    ],
    "postToolUse": [
      {
        "command": "node \"./hooks/_hosts/cursor/launcher.js\" --event postToolUse --core \"./hooks/board-lint/implementations/cursor/board-lint-core.js\"",
        "matcher": "Write"
      },
      {
        "command": "node \"./hooks/_hosts/cursor/launcher.js\" --event postToolUse --core \"./hooks/orchestrator-context/implementations/cursor/orchestrator-context-core.js\""
      }
    ],
    "stop": [
      {
        "command": "node \"./hooks/_hosts/cursor/launcher.js\" --event stop --core \"./hooks/verify-board/implementations/cursor/verify-board-core.js\"",
        "loop_limit": 5
      },
      {
        "command": "node \"./hooks/_hosts/cursor/launcher.js\" --event stop --core \"./hooks/usage-pacing/implementations/cursor/usage-pacing-core.js\""
      },
      {
        "command": "node \"./hooks/_hosts/cursor/launcher.js\" --event stop --core \"./hooks/coordination-inbox/implementations/cursor/coordination-inbox-core.js\""
      },
      {
        "command": "node \"./hooks/_hosts/cursor/launcher.js\" --event stop --core \"./hooks/identity-nudge/implementations/cursor/identity-nudge-core.js\""
      }
    ],
    "preCompact": [
      {
        "command": "node \"./hooks/_hosts/cursor/launcher.js\" --event preCompact --core \"./hooks/reinject/implementations/cursor/precompact-observe-core.js\""
      }
    ]
  }
}

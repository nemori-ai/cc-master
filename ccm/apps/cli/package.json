{
  "name": "ccm",
  "version": "0.22.1",
  "type": "module",
  "bin": {
    "ccm": "./bin/ccm.cjs"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "node scripts/build-runtime-invoke-helper.mjs && node scripts/gen-web-viewer-assets.mjs && tsdown",
    "build:sea": "node scripts/gen-web-viewer-assets.mjs && bash scripts/build-sea.sh",
    "test": "node scripts/build-runtime-invoke-helper.mjs && node --import tsx --test \"test/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "@ccm/engine": "workspace:*"
  },
  "devDependencies": {
    "@ccm/web-viewer": "workspace:*",
    "@types/node": "^26.0.0",
    "postject": "1.0.0-alpha.6",
    "tsx": "^4.20.6"
  }
}

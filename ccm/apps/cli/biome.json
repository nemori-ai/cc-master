{
  "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
  "extends": "//",
  "files": {
    "includes": ["**", "!test/fixtures/", "!dist/", "!src/generated/**"]
  },
  "linter": {
    "rules": {
      "complexity": {
        "useOptionalChain": "off"
      },
      "style": {
        "noNonNullAssertion": "off"
      },
      "suspicious": {
        "noExplicitAny": "off"
      }
    }
  }
}

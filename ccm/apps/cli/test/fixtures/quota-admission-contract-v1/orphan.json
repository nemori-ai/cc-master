{
  "schema": "ccm/quota-orphan-audit-fixtures/v1",
  "cases": [
    {
      "name": "claimed-without-hello-retained",
      "spec_ids": ["QA-COMMIT-003", "QA-ORP-001"],
      "input": {
        "reservation": { "state": "committed", "amount_pct": 4 },
        "launch": { "claim": "present", "hello": "absent" },
        "journal": "empty",
        "process_identity": "unknown"
      },
      "expected": {
        "audit_class": "orphan-audit",
        "state": "orphaned",
        "capacity_counted_pct": 4,
        "release_count": 0,
        "spawn_count": 0
      }
    },
    {
      "name": "parent-dead-run-live-retained",
      "spec_ids": ["QA-RES-006", "QA-LIFE-001"],
      "input": {
        "reservation": { "state": "committed", "amount_pct": 4 },
        "launch": { "claim": "present", "hello": "valid" },
        "lease": "fresh",
        "process_identity": "match",
        "parent_manager": "dead"
      },
      "expected": {
        "audit_class": "active",
        "state": "committed",
        "capacity_counted_pct": 4,
        "release_count": 0,
        "spawn_count": 0,
        "handoff_action": "attach-same-run"
      }
    },
    {
      "name": "pid-not-found-alone-retained",

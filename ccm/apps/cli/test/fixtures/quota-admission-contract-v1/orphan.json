        "release_count": 0,
        "spawn_count": 0
      }
    },
    {
      "name": "terminal-audit-released",
      "spec_ids": ["QA-ORP-003", "QA-ORP-004"],
      "input": {
        "reservation": { "state": "release_pending", "amount_pct": 4 },

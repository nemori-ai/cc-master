        "reservation": { "state": "committed", "amount_pct": 4 },
        "launch": { "claim": "present", "hello": "valid" },
        "lease": "stale",
        "pid_probe": "not-found",
        "boot_id": "unknown",
        "process_start_identity": "unknown"
      },
      "expected": {
        "audit_class": "orphan-audit",
        "state": "orphaned",
        "capacity_counted_pct": 4,
        "release_count": 0,
        "spawn_count": 0
      }
    },
    {
      "name": "pid-reuse-retained",
      "spec_ids": ["QA-ORP-001", "QA-LIFE-002"],
      "input": {
        "reservation": { "state": "committed", "amount_pct": 4 },
        "launch": { "claim": "present", "hello": "valid" },
        "lease": { "pid": 77, "boot_id": "boot-A", "process_start_identity": "start-A" },
        "process": { "pid": 77, "boot_id": "boot-B", "process_start_identity": "start-B" }
      },
      "expected": {
        "audit_class": "orphan-audit",
        "state": "orphaned",
        "capacity_counted_pct": 4,

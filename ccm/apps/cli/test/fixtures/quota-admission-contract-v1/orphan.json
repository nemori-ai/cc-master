        "signal_count": 0,
        "spawn_count": 0
      }
    },
    {
      "name": "journal-conflict-retained",
      "spec_ids": ["QA-ORP-001", "QA-ORP-003"],
      "input": {
        "reservation": { "state": "committed", "amount_pct": 4 },
        "launch": { "claim": "present", "hello": "valid" },
        "journal": { "sequence": "conflict", "writer_identity": "mismatch" }
      },
      "expected": {
        "audit_class": "orphan-audit",
        "state": "orphaned",
        "capacity_counted_pct": 4,
        "release_count": 0,
        "spawn_count": 0
      }
    },
    {
      "name": "terminal-cleanup-pending-retained",
      "spec_ids": ["QA-COMMIT-004", "QA-ORP-004"],
      "input": {
        "reservation": { "state": "committed", "amount_pct": 4 },

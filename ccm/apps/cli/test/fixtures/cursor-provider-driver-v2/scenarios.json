  "cases": [
    {
      "id": "CPD-001",
      "title": "only IDE never implies a headless worker",
      "overrides": {
        "surfaces": {
          "cursor-ide-plugin": { "installed": true, "auth": { "state": "authenticated" } },
          "cursor-agent-cli": {
            "installed": false,
            "binary": { "available": false, "path": null },
            "auth": { "state": "unauthenticated" }
          }
        }
      },
      "expected": {
        "eligible": false,
        "axis": "headless.surface",
        "blocker": "headless.surface-not-installed"
      }
    },
    {
      "id": "CPD-002",
      "title": "only Agent is eligible from the same origin",
      "overrides": {},
      "expected": { "eligible": true, "route_relation": "same-origin" }
    },
    {
      "id": "CPD-003",
      "title": "both surfaces remain independently eligible from another origin",
      "overrides": {
        "origin_harness": "claude-code",

{
  "schema": "cc-master/skill-knowledge-host-adapter-contract/v1",
  "product_hosts": [
    "claude-code",
    "codex",
    "cursor",
    "kimi-code"
  ],
  "worker_allowlist": [
    "codex",
    "cursor"
  ],
  "payload_modes": [
    "canonical",
    "partial",
    "stub"
  ],
  "anchor_form": "explicit-html-id",
  "path_policy": "relative-final-host-path",
  "anchor_algorithm": "cc-master/skill-knowledge-anchor-id/v1",
  "claims": {
    "heading_autogenerated_slugs": "unverifiable",
    "live_host_click_through": "unverifiable"
  },
  "hosts": {
    "claude-code": {
      "role": "product-host",
      "worker_eligible": false,
      "path_tokens": {
        "skill_dir": "${CLAUDE_SKILL_DIR}",
        "plugin_root": "${CLAUDE_PLUGIN_ROOT}",
        "skill_dir_expands": true,
        "plugin_root_expands": true,
        "skill_dir_mechanism": "skill-body-text-substitution",
        "plugin_root_mechanism": "hook-and-skill-path-token",
        "runtime_env_plugin_root": true,
        "rejected_fiction_tokens": []
      },
      "knowledge_links": {
        "required_form": "relative",
        "host_tokens_forbidden_in_knowledge_nav": true
      },
      "evidence": [
        {
          "kind": "document",
          "path": "design_docs/harnesses/compatibility-matrix.md"
        },
        {
          "kind": "document",
          "path": "design_docs/harnesses/claude-code.md"
        },
        {
          "kind": "fixture",
          "path": "design_docs/skill-knowledge-graph/fixtures/host-portability"
        }
      ]
    },
    "codex": {
      "role": "product-host",
      "worker_eligible": true,
      "path_tokens": {
        "skill_dir": "(none documented for SKILL.md substitution)",
        "plugin_root": "${PLUGIN_ROOT}",
        "skill_dir_expands": false,
        "plugin_root_expands": true,
        "skill_dir_mechanism": "none-documented",
        "plugin_root_mechanism": "hook-command-string-token",
        "runtime_env_plugin_root": false,
        "rejected_fiction_tokens": [
          "${CODEX_PLUGIN_ROOT}"
        ]
      },
      "knowledge_links": {
        "required_form": "relative",
        "host_tokens_forbidden_in_knowledge_nav": true
      },
      "evidence": [
        {
          "kind": "document",
          "path": "design_docs/harnesses/compatibility-matrix.md"
        },
        {
          "kind": "document",
          "path": "design_docs/harnesses/codex.md"
        },
        {
          "kind": "document",
          "path": "design_docs/harnesses/paragoge-import-audit.md"
        },
        {
          "kind": "fixture",
          "path": "design_docs/skill-knowledge-graph/fixtures/host-portability"
        }
      ]
    },
    "cursor": {
      "role": "product-host",
      "worker_eligible": true,
      "path_tokens": {
        "skill_dir": "(none documented for skill body substitution)",
        "plugin_root": "(none documented; launcher/plugin-cwd + CC_MASTER_PLUGIN_ROOT)",
        "skill_dir_expands": false,
        "plugin_root_expands": false,
        "skill_dir_mechanism": "none-documented",
        "plugin_root_mechanism": "launcher-plugin-cwd",
        "runtime_env_plugin_root": false,
        "rejected_fiction_tokens": [
          "${CURSOR_PLUGIN_ROOT}",
          "${CURSOR_SKILL_DIR}"
        ]
      },
      "knowledge_links": {
        "required_form": "relative",
        "host_tokens_forbidden_in_knowledge_nav": true
      },
      "evidence": [
        {
          "kind": "document",
          "path": "design_docs/harnesses/compatibility-matrix.md"
        },
        {
          "kind": "document",
          "path": "design_docs/harnesses/cursor.md"
        },
        {
          "kind": "document",
          "path": "design_docs/harnesses/capabilities/path-token-resolution.md"
        },
        {
          "kind": "fixture",
          "path": "design_docs/skill-knowledge-graph/fixtures/host-portability"
        }
      ]
    },
    "kimi-code": {
      "role": "product-host",
      "worker_eligible": false,
      "path_tokens": {
        "skill_dir": "${KIMI_SKILL_DIR}",
        "plugin_root": "KIMI_PLUGIN_ROOT",
        "skill_dir_expands": true,
        "plugin_root_expands": false,
        "skill_dir_mechanism": "skill-body-text-substitution",
        "plugin_root_mechanism": "hook-subprocess-env",
        "runtime_env_plugin_root": true,
        "rejected_fiction_tokens": []
      },
      "knowledge_links": {
        "required_form": "relative",
        "host_tokens_forbidden_in_knowledge_nav": true
      },
      "evidence": [
        {
          "kind": "document",
          "path": "design_docs/harnesses/compatibility-matrix.md"
        },
        {
          "kind": "document",
          "path": "design_docs/harnesses/kimi-code.md"
        },
        {
          "kind": "fixture",
          "path": "design_docs/skill-knowledge-graph/fixtures/host-portability"
        }
      ]
    }
  }
}

  "title": "终端态与端点验收",
  "intent": "在 worker/runtime 停止后，区分运行终态与父任务真完成，并在自己的端点独立验收。",
  "recognition_cues": [
    "worker 或 workflow 报告 terminal",
    "准备把 task 标成 done 或 verified",
    "只有 CI green、external closed 或 worker 自报成功"
  ],
  "boundary": {
    "includes": [
      "terminal 与 task verdict 的分离",
      "artifact、diff、tests、acceptance 与必要异构复核"
    ],
    "excludes": [
      "如何切分任务 DAG",
      "如何实现 worker 交付的代码"
    ]
  },
  "access": {
    "class": "critical",
    "relevant_entries": [
      "entry:master-orchestrator"
    ],
    "primary_points": [
      "point:verification.terminal-is-not-done"
    ],
    "rationale": "误把 runtime terminal 当成 task done 会直接绕过产品的最终正确性门。"
  },
